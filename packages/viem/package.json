{
  "name": "@base-attribution-os/viem",
  "version": "0.0.0",
  "description": "Tiny viem helpers for Base Builder Code attribution.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "clean": "rimraf dist",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@base-attribution-os/core": "workspace:*"
  },
  "peerDependencies": {
    "viem": ">=2.21.0"
  },
  "peerDependenciesMeta": {
    "viem": {
      "optional": true
    }
  }
}
