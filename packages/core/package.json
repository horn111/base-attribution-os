{
  "name": "@base-attribution-os/core",
  "version": "0.0.0",
  "description": "Core ERC-8021 Builder Code suffix helpers for Base Attribution OS.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "clean": "rimraf dist",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "ox": ">=0.9.0"
  },
  "peerDependenciesMeta": {
    "ox": {
      "optional": true
    }
  }
}
